{
    "name": "la-souris/document-signer-validsign",
    "description": "ValidSign implementation of the document signer SDK.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Laurens Laman",
            "email": "l.laman@lasourisscooters.nl"
        }
    ],
    "require": {
        "php": "^8.3",
        "la-souris/document-signer-sdk": "^1.0",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "LaSouris\\DocumentSigner\\ValidSign\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaSouris\\DocumentSigner\\ValidSign\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
